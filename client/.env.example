# Dev: omit VITE_API_URL to proxy /api to Rails on port 3001 (see vite.config.ts).
# Or set explicitly: VITE_API_URL=http://localhost:3001

# Set ORION_CLIENT_URL on the API service to match this app URL.
# Local: http://localhost:5173
# Production: https://orion-client-production.up.railway.app

# Production (set on Railway orion-client service at build time)
# VITE_API_URL=https://orion-production-7f9f.up.railway.app
