# Copy to .env for local development. Set secrets in Railway → production environment variables.
PORT=3000

# Client URL for API callbacks
ORION_CLIENT_URL=http://localhost:5173

# MVP demo sign-in (API). When unset, defaults to bench.chair / BenchChair-Demo-2026.
# ORION_DEMO_USERS=[{"username":"bench.chair","password":"BenchChair-Demo-2026","role":"Bench Chair","display_name":"Bench Chair"}]

# Railway sets DATABASE_URL automatically when you add Railway Postgres
# Optional AWS RDS free tier only — see docs/aws-database-setup.md before creating anything
# DATABASE_URL=postgresql://orion_admin:PASSWORD@orion-staging-db.<id>.eu-north-1.rds.amazonaws.com:5432/orion_staging?sslmode=require
# RAILS_ENV=production
# SECRET_KEY_BASE=

# Optional AWS RDS scripts only (not needed for local Docker or Railway Postgres)
# AWS_REGION=eu-north-1
# RDS_SECURITY_GROUP_ID=sg-075d77a3169e2e791
